PORT=4000

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=qr_attendance

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=12h

# How often a new QR token is generated (seconds)
QR_ROTATION_SECONDS=45
# How long each QR token stays valid after being generated (seconds)
QR_TOKEN_LIFETIME_SECONDS=60
